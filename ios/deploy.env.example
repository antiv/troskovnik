# Šablon za iOS deploy (deploy_ios.sh). Kopiraj u `ios/deploy.env` i popuni
# STVARNIM vrednostima. `ios/deploy.env` i .p8 ključ NIKAD ne idu u git!

# Team ID novog naloga: developer.apple.com → Membership → "Team ID" (10 znakova)
APP_STORE_TEAM_ID=XXXXXXXXXX

# App Store Connect API ključ (generisan POD NOVIM nalogom):
# App Store Connect → Users and Access → Integrations → App Store Connect API
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Apsolutna putanja do AuthKey_<ASC_KEY_ID>.p8 (čuvaj VAN repo-a, npr. ~/keys/)
ASC_KEY_PATH=/Users/ivanantonijevic/keys/AuthKey_XXXXXXXXXX.p8
